//##############//
// AUTO-STARTUP //
//##############//

// spawn-at-startup "swaybg" "-i" "$HOME/Изображения/wallpaper/bg0.jpg" "-m" "fill"
spawn-at-startup "waybar"
spawn-at-startup "awww-daemon"

//################//
// INPUT SETTINGS //
//################//

input {
    keyboard {
        xkb {
            layout "fi,ru"
            options "grp:alt_shift_toggle"
        }
        numlock
    }

    touchpad {
        // off
        tap
        dwt
        dwtp
        drag false
        drag-lock
        // natural-scroll
        // accel-speed 0.2
        // accel-profile "flat"
        // scroll-factor 1.0
        // scroll-factor vertical=1.0 horizontal=-2.0
        // scroll-method "two-finger"
        // scroll-button 273
        // scroll-button-lock
        // tap-button-map "left-middle-right"
        // click-method "clickfinger"
        // left-handed
        // disabled-on-external-mouse
        // middle-emulation
    }

    // focus-follows-mouse max-scroll-amount="0%"
}


//###############//
// LAYOUT & LOOK //
//###############//

layout {
    gaps 16

    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        off
        width 4
        active-color "#7fc8ff"
        inactive-color "#505050"
    }

    border {
        // off
        width 4
        active-color    "#82499a"
        inactive-color  "#3a2144"
        // urgent-color    "#9b0000"
    }

    shadow {
        off
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
}


//##############//
// WINDOW RULES //
//##############//

// Правило для Kitty: открывать на всю ширину по умолчанию (как хочет сам терминал)
window-rule {
    match app-id=r#"^kitty$"#
    default-column-width {}
}

// Firefox Picture-in-Picture всегда плавающий
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// Скругление углов для всех окон (опционально, требует поддержки CSD или prefer-no-csd)
// window-rule {
//     geometry-corner-radius 12
//     clip-to-geometry true
// }


//#################//
// BINDS (Hotkeys) //
//#################//

binds {
    Mod+Shift+Slash { show-hotkey-overlay; }

    // --- Основные приложения ---
    Mod+return hotkey-overlay-title="Terminal: kitty" { spawn "kitty"; }
    Mod+Space   { spawn "rofi" "-show" "drun"; }
    Mod+E       { spawn "thunar"; }

    // --- Управление окнами ---
    Mod+Q repeat=false { close-window; }
    
    // Навигация
    Mod+Left  { focus-column-left; }
    Mod+Down  { focus-window-down; }
    Mod+Up    { focus-window-up; }
    Mod+Right { focus-column-right; }
    
    // HJKL навигация
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }

    // Перемещение окон
    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Down  { move-window-down; }
    Mod+Shift+Up    { move-window-up; }
    Mod+Shift+Right { move-column-right; }
    
    Mod+Shift+H { move-column-left; }
    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }
    Mod+Shift+L { move-column-right; }

    /*
    // Мониторы
    Mod+Shift+Left  { focus-monitor-left; }
    Mod+Shift+Down  { focus-monitor-down; }
    Mod+Shift+Up    { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }

    Mod+Shift+H { focus-monitor-left; }
    Mod+Shift+J { focus-monitor-down; }
    Mod+Shift+K { focus-monitor-up; }
    Mod+Shift+L { focus-monitor-right; }
    */

    // Рабочие столы
    Mod+Page_Down { focus-workspace-down; }
    Mod+Page_Up   { focus-workspace-up; }
    Mod+U         { focus-workspace-down; }
    Mod+I         { focus-workspace-up; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Ctrl+1 { move-column-to-workspace 1; }
    Mod+Ctrl+2 { move-column-to-workspace 2; }
    Mod+Ctrl+3 { move-column-to-workspace 3; }
    Mod+Ctrl+4 { move-column-to-workspace 4; }
    Mod+Ctrl+5 { move-column-to-workspace 5; }
    Mod+Ctrl+6 { move-column-to-workspace 6; }
    Mod+Ctrl+7 { move-column-to-workspace 7; }
    Mod+Ctrl+8 { move-column-to-workspace 8; }
    Mod+Ctrl+9 { move-column-to-workspace 9; }

    // Размеры и режимы
    Mod+D   { switch-preset-column-width; }
    Mod+F   { maximize-column; }
    F11     { fullscreen-window; }
    Mod+X   { toggle-window-floating; }
    
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }

    // Скриншоты
    Mod+Shift+S { screenshot; }
    Print       { screenshot; }
    Ctrl+Print  { screenshot-screen; }
    Alt+Print   { screenshot-window; }

    // Системные
    // Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    Mod+Escape       { quit; }
    Mod+Shift+Escape { power-off-monitors; }

    // Громкость
    "XF86AudioRaiseVolume" { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    "XF86AudioLowerVolume" { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    "XF86AudioMute"        { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    // "XF86AudioRaiseVolume" { spawn ""; }

    // Яркость
    "XF86MonBrightnessUp"   { spawn "brightnessctl" "set" "+5%"; }
    "XF86MonBrightnessDown" { spawn "brightnessctl" "set" "5%-"; }
}



